# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Evaluation Settings
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_DATASET=evaluator/datasets/sample_qa.jsonl
DEFAULT_RUNS=3
DEFAULT_OUTPUT_DIR=results

# LLM Judge Settings (model used to grade answers 1-5)
JUDGE_MODEL=gpt-4o-mini

# Feature Flags
ENABLE_RAGAS=true
ENABLE_NLI_CHECK=true
ENABLE_LLM_JUDGE=true
ENABLE_SEMANTIC_SIMILARITY=true

# RAGAS LLM Backend (openai or anthropic)
RAGAS_LLM_PROVIDER=openai
RAGAS_LLM_MODEL=gpt-4o-mini

# Concurrency
MAX_CONCURRENT_REQUESTS=5

# Logging
LOG_LEVEL=INFO
